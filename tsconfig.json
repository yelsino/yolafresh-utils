{
  "compilerOptions": {
    "target": "es2018",
    "module": "commonjs",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "downlevelIteration": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": ["./*"],
      "@utils": ["./domain/shared/utils/index.ts"],
      "@utils/*": ["./domain/shared/utils/*"],
      "@interfaces": ["./domain/shared/interfaces/index.ts"],
      "@interfaces/*": ["./domain/shared/interfaces/*"],
      "@/utils": ["./domain/shared/utils/index.ts"],
      "@/utils/*": ["./domain/shared/utils/*"],
      "@/interfaces": ["./domain/shared/interfaces/index.ts"],
      "@/interfaces/*": ["./domain/shared/interfaces/*"],
      "@store/*": ["./store/*"],
      "@data/*": ["./data/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
