{
  "name": "yola-fresh-utils",
  "version": "1.0.2",
  "description": "🛒 Sistema POS completo y reutilizable con soporte fiscal para múltiples países. Incluye carrito de compras, gestión de ventas y configuraciones fiscales predefinidas.",
  "keywords": [
    "pos",
    "punto-de-venta",
    "carrito-compras",
    "ecommerce",
    "typescript",
    "fiscal",
    "igv",
    "iva",
    "peru",
    "mexico",
    "colombia",
    "restaurant",
    "retail"
  ],
  "homepage": "https://github.com/tu-usuario/yola-fresh-utils#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tu-usuario/yola-fresh-utils.git"
  },
  "bugs": {
    "url": "https://github.com/tu-usuario/yola-fresh-utils/issues"
  },
  "author": {
    "name": "Tu Nombre",
    "email": "tu-email@ejemplo.com"
  },
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./domain/*": {
      "import": "./domain/*.js",
      "require": "./domain/*.js",
      "types": "./domain/*.d.ts"
    },
    "./domain/ventas/*": {
      "import": "./domain/ventas/*.js",
      "require": "./domain/ventas/*.js",
      "types": "./domain/ventas/*.d.ts"
    },
    "./domain/ventas/events/*": {
      "import": "./domain/ventas/events/*.js",
      "require": "./domain/ventas/events/*.js",
      "types": "./domain/ventas/events/*.d.ts"
    },
    "./domain/compras/*": {
      "import": "./domain/compras/*.js",
      "require": "./domain/compras/*.js",
      "types": "./domain/compras/*.d.ts"
    },
    "./domain/inventario/*": {
      "import": "./domain/inventario/*.js",
      "require": "./domain/inventario/*.js",
      "types": "./domain/inventario/*.d.ts"
    },
    "./domain/contabilidad/*": {
      "import": "./domain/contabilidad/*.js",
      "require": "./domain/contabilidad/*.js",
      "types": "./domain/contabilidad/*.d.ts"
    },
    "./domain/tesoreria/*": {
      "import": "./domain/tesoreria/*.js",
      "require": "./domain/tesoreria/*.js",
      "types": "./domain/tesoreria/*.d.ts"
    },
    "./domain/usuarios/*": {
      "import": "./domain/usuarios/*.js",
      "require": "./domain/usuarios/*.js",
      "types": "./domain/usuarios/*.d.ts"
    },
    "./domain/shared/*": {
      "import": "./domain/shared/*.js",
      "require": "./domain/shared/*.js",
      "types": "./domain/shared/*.d.ts"
    },
    "./domain/shared/interfaces/*": {
      "import": "./domain/shared/interfaces/*.js",
      "require": "./domain/shared/interfaces/*.js",
      "types": "./domain/shared/interfaces/*.d.ts"
    },
    "./domain/shared/utils/*": {
      "import": "./domain/shared/utils/*.js",
      "require": "./domain/shared/utils/*.js",
      "types": "./domain/shared/utils/*.d.ts"
    },
    "./domain/shared/base/*": {
      "import": "./domain/shared/base/*.js",
      "require": "./domain/shared/base/*.js",
      "types": "./domain/shared/base/*.d.ts"
    },
    "./domain/shared/value-objects/*": {
      "import": "./domain/shared/value-objects/*.js",
      "require": "./domain/shared/value-objects/*.js",
      "types": "./domain/shared/value-objects/*.d.ts"
    },
    "./interfaces": {
      "import": "./dist/domain/shared/interfaces/index.js",
      "require": "./dist/domain/shared/interfaces/index.js",
      "types": "./dist/domain/shared/interfaces/index.d.ts"
    },
    "./utils": {
      "import": "./dist/domain/shared/utils/index.js",
      "require": "./dist/domain/shared/utils/index.js",
      "types": "./dist/domain/shared/utils/index.d.ts"
    },
    "./class": {
      "import": "./dist/domain/shared/base/index.js",
      "require": "./dist/domain/shared/base/index.js",
      "types": "./dist/domain/shared/base/index.d.ts"
    }

  },
  "files": [
    "dist",
    "domain"
  ],
  "typesVersions": {
    "*": {
      "domain/*": [
        "domain/*"
      ],
      "domain/ventas/*": [
        "domain/ventas/*"
      ],
      "domain/ventas/events/*": [
        "domain/ventas/events/*"
      ],
      "domain/compras/*": [
        "domain/compras/*"
      ],
      "domain/inventario/*": [
        "domain/inventario/*"
      ],
      "domain/contabilidad/*": [
        "domain/contabilidad/*"
      ],
      "domain/tesoreria/*": [
        "domain/tesoreria/*"
      ],
      "domain/usuarios/*": [
        "domain/usuarios/*"
      ],
      "domain/shared/*": [
        "domain/shared/*"
      ],
      "domain/shared/interfaces/*": [
        "domain/shared/interfaces/*"
      ],
      "domain/shared/utils/*": [
        "domain/shared/utils/*"
      ],
      "domain/shared/base/*": [
        "domain/shared/base/*"
      ],
      "domain/shared/value-objects/*": [
        "domain/shared/value-objects/*"
      ]
    }
  },
  "scripts": {
    "build": "tsc && tsc-alias && node scripts/generate-subpath-stubs.cjs",
    "prepare": "npm run build",
    "generate-exports": "cd scripts && npx ts-node generate-exports.ts && cd ..",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.11",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@types/node": "^24.3.1"
  }
}
